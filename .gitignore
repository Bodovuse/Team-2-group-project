# ─────────────────────────────────────────
# Virtual environment
# ─────────────────────────────────────────
venv/
.venv/
env/

# ─────────────────────────────────────────
# Vosk model files
# Too large to upload to GitHub (1.8GB)
# Download from: https://alphacephei.com/vosk/models
# ─────────────────────────────────────────
model/

# ─────────────────────────────────────────
# Python cache files
# Auto-generated by Python, not needed in repo
# ─────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
*.pycache
.Python

# ─────────────────────────────────────────
# Environment variables and API keys
# Never upload API keys to GitHub
# ─────────────────────────────────────────
.env
.env.local
.env.production

# ─────────────────────────────────────────
# CSV data files
# Generated when the pipeline runs
# ─────────────────────────────────────────
data/

# ─────────────────────────────────────────
# Mac system files
# ─────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride

# ─────────────────────────────────────────
# VS Code settings
# ─────────────────────────────────────────
.vscode/

# ─────────────────────────────────────────
# Logs
# ─────────────────────────────────────────
*.log
logs/

# ─────────────────────────────────────────
# Zip files
# Model zip file downloaded during setup
# ─────────────────────────────────────────
*.zip